# tgclaude — environment configuration
# Copy this file to .env and fill in the values.
# .env is gitignored and must NEVER be committed.

# --------------------------------------------------------------------
# Required
# --------------------------------------------------------------------

# Telegram bot token from @BotFather.
BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff-your-token-here

# Comma-separated list of Telegram numeric user IDs that may use this bot.
# Find your user ID by sending /start to @userinfobot.
# An empty or missing value is a hard startup failure (fail-closed security).
ALLOWED_USER_IDS=123456789,987654321

# --------------------------------------------------------------------
# Paths  (all undergo Path.expanduser() — '~' is safe to use)
# --------------------------------------------------------------------

# Root of the Claude install that contains .credentials.json and projects/.
# Default: ~/.claude
CLAUDE_HOME=~/.claude

# Working directory passed to every Claude query.
# Sessions started by the bot appear under $CLAUDE_HOME/projects/<encoded-cwd>/.
# Default: ~
CLAUDE_PROJECT_CWD=~

# Path to the claude CLI binary.
# Optional — defaults to auto-detecting 'claude' from PATH.
# Set this if the binary lives outside PATH (e.g. a virtualenv or custom install).
# CLAUDE_BINARY=~/.local/bin/claude

# Where the SQLite database is stored.
# Parent directory is created with 0700 permissions on first run.
# Default: ~/.local/state/tgclaude/bot.db
DATABASE_PATH=~/.local/state/tgclaude/bot.db

# --------------------------------------------------------------------
# Usage alerts
# --------------------------------------------------------------------

# Comma-separated utilization percentages (0–100) at which to send alerts.
# These are first-run seeds; /alerts thresholds N,N,N overrides at runtime
# and wins over this env var on subsequent restarts.
# Default: 50,80,95
ALERT_THRESHOLDS=50,80,95

# --------------------------------------------------------------------
# Permission mode
# --------------------------------------------------------------------

# Controls how tool-use permission prompts are handled.
#   interactive  — Telegram inline-keyboard prompts for every tool call (default, safest)
#   bypass       — SDK runs with bypassPermissions; all tools auto-approved
#   readonly     — auto-allow Read/Grep/Glob/WebFetch, auto-deny everything else
# Default: interactive
PERMISSION_MODE=interactive

# How long (seconds) can_use_tool waits for a Telegram button tap before
# auto-denying. Default: 600 (10 minutes)
PERMISSION_TIMEOUT_S=600

# Maximum wall-clock seconds allowed for a single Claude turn (query call).
# The bridge cancels the turn and notifies the user if this is exceeded.
# Default: 300 (5 minutes)
TURN_TIMEOUT_S=300

# --------------------------------------------------------------------
# Display
# --------------------------------------------------------------------

# IANA timezone name for rendering reset times in /usage output.
# If unset, the process's system TZ (or the TZ env var) is used.
# The systemd unit can set TZ= instead if you prefer.
# Example: America/Phoenix, Europe/Berlin, Asia/Tokyo
# DISPLAY_TZ=America/Phoenix

# --------------------------------------------------------------------
# Logging
# --------------------------------------------------------------------

# Standard Python logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO
